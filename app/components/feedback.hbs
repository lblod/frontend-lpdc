<div class="au-u-padding-right-small u-border-divider u-border-divider--bottom">
  <div class="au-u-flex au-u-flex--vertical-baseline au-u-padding-bottom-small">
    <AuButton
      @skin="link-secondary"
      @size="large"
      @icon={{if this.feedbackExpanded "nav-up" "nav-down"}}
      @hideText={{true}}
      class="au-u-flex-shrink-0"
      {{on "click" this.toggleFeedback}}
    />
    <div class="au-u-1-1">
      <div
        class="au-u-flex au-u-flex--vertical-center au-u-margin-top-tiny au-u-margin-bottom-tiny"
      >
        <AuHelpText
          @skin="primary"
          @size="large"
          class="au-u-margin-top-none au-u-medium"
        >#1</AuHelpText>
        {{! template-lint-disable no-inline-styles }}
        <AuHelpText
          @skin="secondary"
          class="au-u-margin-top-none au-u-margin-left-tiny"
          style="margin-right: auto;"
        >(geweigerd)</AuHelpText>
        {{#if (not-eq this.feedbackStatus undefined)}}
          <AuButton @skin="primary" {{on "click" (perform this.sendAnswer)}}>
            Antwoord verzenden
          </AuButton>
        {{/if}}
        {{#if this.feedbackExpanded}}
          <AuDropdown
            @skin="naked"
            @icon="three-dots"
            @hideText={{true}}
            @alignment="left"
            @size="large"
            role="menu"
          >
            <AuButton
              @icon="circle-check"
              @skin={{if this.feedbackStatus "link" "link-secondary"}}
              role="menuitem"
              class={{if this.feedbackStatus "au-u-background-gray-200"}}
              {{on "click" this.markFeedbackProcessed}}
            >
              Feedback verwerkt
              {{#if
                (and (not-eq this.feedbackStatus undefined) this.feedbackStatus)
              }}
                <AuIcon @size="medium" @icon="check" />
              {{/if}}
            </AuButton>
            <AuButton
              @skin={{if this.feedbackStatus "link-secondary" "link"}}
              @icon="circle-x"
              role="menuitem"
              class={{if this.feedbackStatus "" "au-u-background-gray-200"}}
              {{on "click" this.markFeedbackDenied}}
            >
              Feedback geweigerd
              {{#if
                (and
                  (not-eq this.feedbackStatus undefined)
                  (not this.feedbackStatus)
                )
              }}
                <AuIcon @size="medium" @icon="check" />
              {{/if}}
            </AuButton>
          </AuDropdown>
        {{/if}}
      </div>
      {{#if this.feedbackExpanded}}
        {{! template-lint-disable no-inline-styles }}
        {{! TODO: add the is-disabled class when the feedback is sent }}
        <div
          class="au-c-textarea au-c-textarea--block"
          style="overflow-y: scroll; resize: vertical; color: var(--au-gray-900); background-color: var(--au-white)"
        >
          {{! template-lint-disable no-triple-curlies }}
          {{{this.mockText}}}
        </div>
      {{/if}}
      <div class="au-u-flex au-u-flex--between au-u-margin-top-tiny">
        <span>{{this.organization}}</span>
        <AuHelpText
          @skin="secondary"
          class="au-u-margin-top-none"
        >{{this.date}}</AuHelpText>
      </div>
    </div>
  </div>
</div>