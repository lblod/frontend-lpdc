<div
  class="au-c-sidebar-container
    {{if @collapsed 'au-c-sidebar-container--collapsed'}}
    {{if (eq @size 'large') 'au-c-sidebar-container--large'}}"
  ...attributes
>
  <div class="au-c-sidebar-container__sidebar">
    <div class="au-c-sidebar">
      <div class="au-c-sidebar__content">
        {{yield to="sidebar"}}
      </div>
    </div>
  </div>

  <div class="au-c-sidebar-container__content">
    <div
      class="au-c-body-container {{if @scroll 'au-c-body-container--scroll'}}"
    >
      {{yield to="content"}}
    </div>
  </div>
</div>