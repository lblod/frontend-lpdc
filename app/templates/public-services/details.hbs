{{page-title @model.publicService.name}}

<DetailsHeader
  @publicService={{@model.publicService}}
  @languageVersionOfConcept={{@model.languageVersionOfConcept}}
  @onUnlinkConcept={{perform this.unlinkConcept}}
  @onMarkAsReviewed={{perform this.markAsReviewed}}
/>

<AuTabs as |Tab|>
  <Tab>
    <AuLink class={{if this.isInhoudTabActive "active"}} {{on "click" (fn this.changeTab "inhoud")}} >Inhoud</AuLink>
  </Tab>
  <Tab>
    <AuLink class={{if this.isEigenschappenTabActive "active"}} {{on "click" (fn this.changeTab "eigenschappen")}}>
      Eigenschappen
    </AuLink>
  </Tab>
</AuTabs>

{{#if this.isInhoudTabActive}}
  <DetailsPage
    @publicService={{@model.publicService}}
    {{! We use `this.model` here since the value is used in the willDestroy method, and the `@model` version is undefined at that point.
        More information: https://github.com/emberjs/ember.js/issues/18987
    }}
    @readOnly={{this.model.readOnly}}
    @formId="inhoud"
    @form={{this.form.form}}
    @formStore={{this.form.formStore}}
    @tabName="au-c-rdf-form--content"
  />
{{else}}
  <DetailsPage
    @publicService={{@model.publicService}}
    {{! We use `this.model` here since the value is used in the willDestroy method, and the `@model` version is undefined at that point.
        More information: https://github.com/emberjs/ember.js/issues/18987
    }}
    @readOnly={{this.model.readOnly}}
    @formId="eigenschappen"
    @form={{this.form.form}}
    @formStore={{this.form.formStore}}
    @tabName="au-c-rdf-form--properties"
  />
{{/if}}
